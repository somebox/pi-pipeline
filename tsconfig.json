{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"lib": ["ES2022"],
		"strict": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": false,
		"skipLibCheck": true,
		"types": []
	},
	"include": ["src/**/*.ts", "test/**/*.ts"]
}
